---
import { ClientRouter } from 'astro:transitions'
import '../styles/globals.css'
import Navbar from '../components/layout/Navbar.astro'
import Footer from '../components/layout/Footer.astro'

interface Props {
  title?: string
  description?: string
  canonical?: string
  ogImage?: string
  mainClass?: string
}

const {
  title,
  description,
  canonical,
  ogImage,
  mainClass = '',
} = Astro.props

const SITE_URL  = 'https://designedbyrob.com'
const fullTitle = title ? `${title} - Rob Jones` : 'Rob Jones - Product Designer | Enterprise SaaS & Startups'
const metaDesc  = description ?? 'Rob Jones - UX Designer for enterprise SaaS and product builder for early-stage founders. Available for new roles.'
const metaUrl   = canonical ? `${SITE_URL}${canonical}` : SITE_URL
const metaImage = ogImage ?? `${SITE_URL}/images/og-image.jpg`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={metaDesc} />
    <link rel="canonical" href={metaUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={metaUrl} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:image"       content={metaImage} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={metaDesc} />
    <meta name="twitter:image"       content={metaImage} />

    <!-- Preload Ogg Italic (used for "Rob" in hero — prevents FOUT) -->
    <link rel="preload" href="/fonts/Ogg-Italic-Trial.otf" as="font" type="font/otf" crossorigin />

    <!-- Fonts — Cabinet Grotesk self-hosted -->
    <link rel="preload" href="/fonts/CabinetGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Cloudinary (video assets) -->
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
    <link rel="dns-prefetch" href="https://res.cloudinary.com" />

    <!-- Theme init: runs sync before paint to prevent flash of wrong theme -->
    <script is:inline>
      try {
        var s = localStorage.getItem('theme')
        var d = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (s === 'dark' || (!s && d)) {
          document.documentElement.classList.add('dark')
        }
      } catch(e) {}
    </script>

    <ClientRouter />
  </head>
  <body>
    <div class="noise">
      <!-- Skip link -->
      <a href="#main" class="skip-link">Skip to main content</a>

      <Navbar />

      <main id="main" class={mainClass} tabindex="-1">
        <slot />
      </main>

      <Footer />
    </div>

    <!-- Scroll animation observer + navigation helpers -->
    <script is:inline>
      (function() {
        function initScrollObserver() {
          if (!('IntersectionObserver' in window)) {
            document.querySelectorAll('[data-animate],[data-animate-y]').forEach(function(el) {
              el.classList.add('visible');
            });
            return;
          }
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1 });

          document.querySelectorAll('[data-animate],[data-animate-y]').forEach(function(el) {
            observer.observe(el);
          });
        }

        function restoreTheme() {
          try {
            var stored = localStorage.getItem('theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (stored === 'dark' || (!stored && prefersDark)) {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
          } catch(e) {}
        }

        // System preference change listener
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
          document.documentElement.classList.toggle('dark', e.matches);
          localStorage.setItem('theme', e.matches ? 'dark' : 'light');
        });

        function initLazyVideos() {
          var videos = document.querySelectorAll('video[data-lazy-video]:not([src])');
          if (!videos.length) return;

          if (!('IntersectionObserver' in window)) {
            videos.forEach(function(video) {
              var src = video.getAttribute('data-src');
              if (src) { video.src = src; video.autoplay = true; }
            });
            return;
          }

          var videoObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                var video = entry.target;
                var src = video.getAttribute('data-src');
                if (src) { video.src = src; video.autoplay = true; }
                videoObserver.unobserve(video);
              }
            });
          }, { rootMargin: '600px' });

          videos.forEach(function(v) { videoObserver.observe(v); });
        }

        // Enable animations, observe scroll elements, lazy load videos
        document.documentElement.classList.add('js-ready');
        initScrollObserver();
        initLazyVideos();

        function initThemeToggle() {
          var toggles = document.querySelectorAll('[data-theme-toggle]');
          if (!toggles.length) return;

          function updateAllLabels() {
            var isDark = document.documentElement.classList.contains('dark');
            var label = isDark ? 'Switch to light mode' : 'Switch to dark mode';
            toggles.forEach(function(t) { t.setAttribute('aria-label', label); });
            // Also sync overlay toggle if present
            var mobileToggle = document.querySelector('[data-mobile-theme-toggle]');
            if (mobileToggle) mobileToggle.setAttribute('aria-label', label);
          }

          toggles.forEach(function(toggle) {
            delete toggle.dataset.bound;
            toggle.dataset.bound = 'true';
            toggle.addEventListener('click', function() {
              var isDark = document.documentElement.classList.contains('dark');
              var next = isDark ? 'light' : 'dark';
              document.documentElement.classList.toggle('dark', next === 'dark');
              localStorage.setItem('theme', next);
              updateAllLabels();
            });
          });

          updateAllLabels();
        }

        function initMobileNav() {
          var btn = document.querySelector('.mobile-nav-toggle');
          var overlay = document.getElementById('mobile-nav-overlay');
          if (!btn || !overlay) return;
          // Remove old binding so we rebind after swap
          delete btn.dataset.bound;

          btn.dataset.bound = 'true';
          var focusableEls = overlay.querySelectorAll('a[data-mobile-nav-link]');
          var isOpen = false;

          function openNav() {
            isOpen = true;
            btn.classList.add('is-open');
            btn.setAttribute('aria-expanded', 'true');
            btn.setAttribute('aria-label', 'Close menu');
            overlay.classList.add('is-open');
            overlay.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
            setTimeout(function() { if (focusableEls.length) focusableEls[0].focus(); }, 100);
          }

          function closeNav() {
            isOpen = false;
            btn.classList.remove('is-open');
            btn.setAttribute('aria-expanded', 'false');
            btn.setAttribute('aria-label', 'Open menu');
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
            btn.focus();
          }

          btn.addEventListener('click', function() {
            if (isOpen) { closeNav(); } else { openNav(); }
          });

          overlay.querySelectorAll('[data-mobile-nav-link]').forEach(function(link) {
            link.addEventListener('click', function() { closeNav(); });
          });

          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && isOpen) { closeNav(); }
          });

          overlay.addEventListener('keydown', function(e) {
            if (e.key !== 'Tab' || !isOpen) return;
            var allFocusable = [btn].concat(Array.from(focusableEls));
            var first = allFocusable[0];
            var last = allFocusable[allFocusable.length - 1];
            if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
            else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
          });
        }

        function initEmailCopy() {
          var btn = document.querySelector('[data-email-copy]');
          var toast = document.querySelector('[data-copied-toast]');
          var copyIcon = document.querySelector('.copy-icon');
          var checkIcon = document.querySelector('.check-icon');
          if (!btn || !toast) return;
          delete btn.dataset.bound;
          btn.dataset.bound = 'true';

          btn.addEventListener('click', function() {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText('robjonesdesigns@gmail.com').then(function() {
                btn.classList.add('copied');
                btn.setAttribute('aria-label', 'Email address copied');
                toast.classList.add('show');
                if (copyIcon) copyIcon.style.display = 'none';
                if (checkIcon) checkIcon.style.display = 'block';
                setTimeout(function() {
                  btn.classList.remove('copied');
                  btn.setAttribute('aria-label', 'robjonesdesigns@gmail.com: copy email address');
                  toast.classList.remove('show');
                  if (copyIcon) copyIcon.style.display = 'block';
                  if (checkIcon) checkIcon.style.display = 'none';
                }, 2200);
              }).catch(function() {
                window.location.href = 'mailto:robjonesdesigns@gmail.com';
              });
            } else {
              window.location.href = 'mailto:robjonesdesigns@gmail.com';
            }
          });
        }

        initEmailCopy();

        // After ViewTransitions swap
        document.addEventListener('astro:after-swap', function() {
          restoreTheme();
          initThemeToggle();
          initMobileNav();
          initEmailCopy();
          document.documentElement.classList.add('js-ready');
          window.scrollTo({ left: 0, top: 0, behavior: 'instant' });
          initScrollObserver();
          initLazyVideos();
        });
      })();
    </script>
  </body>
</html>
