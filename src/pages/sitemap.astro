---
import Layout from '../layouts/Layout.astro'
import { projects } from '../data/projects'
---

<Layout
  title="Sitemap"
  description="Site map for Rob Jones - Product Designer portfolio."
  canonical="/sitemap"
>
  <div class="min-h-screen pt-28 md:pt-36 pb-24">
    <div style="max-width: 640px; margin: 0 auto; padding: 0 2rem;">

      <h1 class="type-display-md mb-8">Sitemap</h1>

      <nav aria-label="Site map" class="type-body">
        <h2 class="type-label mb-3">Pages</h2>
        <ul class="list-reset mb-8">
          <li class="mb-2"><a href="/" class="type-link inline-block py-2 -mx-2 px-2">Home</a></li>
          <li class="mb-2"><a href="/about" class="type-link inline-block py-2 -mx-2 px-2">About</a></li>
          <li class="mb-2"><a href="/resume" class="type-link inline-block py-2 -mx-2 px-2">Resume</a></li>
          <li class="mb-2"><a href="/design-system" class="type-link inline-block py-2 -mx-2 px-2">Style Guide</a></li>
        </ul>

        <h2 class="type-label mb-3 mt-10">Case Studies</h2>
        <ul class="list-reset">
          {projects.map(p => (
            <li class="mb-2">
              <a href={`/projects/${p.slug}`} class="type-link inline-block py-2 -mx-2 px-2">
                {p.company}: {p.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>
  </div>
</Layout>
