---
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="Page Not Found"
  description="This page does not exist."
  canonical="/404"
>
  <div class="min-h-screen flex items-center justify-center pt-28 pb-24">
    <div class="flex flex-col items-center gap-6 text-center px-6">
      <h1 class="type-display-lg">This page does not exist.</h1>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-display font-bold text-on-accent bg-accent transition-opacity hover:opacity-85"
        style="background-color: var(--accent); color: var(--on-accent);"
      >
        Back to home
      </a>
    </div>
  </div>
</Layout>
