---
import Layout from '../layouts/Layout.astro'
import Container from '../components/layout/Container.astro'
import Button from '../components/ui/Button.astro'
import Badge from '../components/ui/Badge.astro'

const colors = [
  { name: '--bg',           label: 'Background',       light: '#fffbf5', dark: '#1c1a16' },
  { name: '--bg-subtle',    label: 'Background Subtle', light: '#fdf8f2', dark: '#201e1a' },
  { name: '--surface',      label: 'Surface',           light: '#f4f1ec', dark: '#28251f' },
  { name: '--fg',           label: 'Foreground',        light: '#222222', dark: '#fffbf5' },
  { name: '--fg-secondary', label: 'Secondary',         light: '#6e6562', dark: '#c2bab0' },
  { name: '--accent',       label: 'Accent',            light: '#813746', dark: '#e36f86' },
  { name: '--on-accent',    label: 'On Accent',         light: '#fffbf5', dark: '#1c1a16' },
  { name: '--border',       label: 'Border',            light: 'rgba(92,82,80,0.1)', dark: 'rgba(176,168,158,0.1)' },
]

const typeScale = [
  { class: 'type-display-2xl', label: 'Display 2XL', size: 'clamp(48-96px)', font: 'Cabinet Grotesk' },
  { class: 'type-display-xl',  label: 'Display XL',  size: 'clamp(40-80px)', font: 'Cabinet Grotesk' },
  { class: 'type-display-lg',  label: 'Display LG',  size: 'clamp(32-60px)', font: 'Cabinet Grotesk' },
  { class: 'type-display-md',  label: 'Display MD',  size: 'clamp(24-36px)', font: 'Cabinet Grotesk' },
  { class: 'type-display-sm',  label: 'Display SM',  size: 'clamp(20-24px)', font: 'Cabinet Grotesk' },
  { class: 'type-body',        label: 'Body',         size: '16px / 20px',    font: 'Areal' },
  { class: 'type-label',       label: 'Label',        size: '16px / 20px',    font: 'Areal', note: 'Uppercase, bold' },
  { class: 'type-link',        label: 'Link',         size: '16px / 20px',    font: 'Areal' },
  { class: 'type-badge',       label: 'Badge',        size: '16px',           font: 'Areal' },
]

const spacingSteps = [
  { px: 4,   tw: '1',  label: 'xs' },
  { px: 8,   tw: '2',  label: 'sm' },
  { px: 12,  tw: '3',  label: '' },
  { px: 16,  tw: '4',  label: 'md' },
  { px: 24,  tw: '6',  label: 'lg' },
  { px: 32,  tw: '8',  label: 'xl' },
  { px: 48,  tw: '12', label: '2xl' },
  { px: 64,  tw: '16', label: '3xl' },
  { px: 96,  tw: '24', label: '4xl' },
]
---

<Layout title="Design System | Rob Jones">
  <div class="bg-subtle">
    <Container size="md">
      <div class="py-16 md:py-24">

        {/* Header */}
        <div class="mb-16" data-animate-y>
          <h1 class="type-display-xl mb-4">Design System</h1>
          <p class="type-body max-w-xl" style="line-height: 1.7;">
            Tokens, typography, and components used across this portfolio. Everything adapts between light and dark themes via CSS custom properties. Toggle the theme to see both modes.
          </p>
        </div>

        {/* Colors */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-sm mb-8">Color Tokens</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {colors.map(c => (
              <div class="flex flex-col gap-2">
                <div
                  class="rounded-lg border border-token-strong"
                  style={`background-color: var(${c.name}); height: 80px;`}
                />
                <p class="font-bold text-body-sm">{c.label}</p>
                <p class="text-body-sm" style="color: var(--fg-secondary);">
                  <code>{c.name}</code>
                </p>
              </div>
            ))}
          </div>

          {/* Three-layer demo */}
          <div class="mt-10">
            <p class="type-label mb-4">Three-layer layout</p>
            <div class="rounded-xl p-6 border border-token" style="background-color: var(--bg);">
              <p class="text-body-sm mb-3" style="color: var(--fg-secondary);">--bg (page background)</p>
              <div class="bg-subtle rounded-lg p-5 border border-token">
                <p class="text-body-sm mb-3" style="color: var(--fg-secondary);">--bg-subtle (section)</p>
                <div class="bg-surface rounded-md p-4 border border-token">
                  <p class="text-body-sm" style="color: var(--fg-secondary);">--surface (card)</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        {/* Typography */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-sm mb-8">Typography</h2>
          <div class="flex flex-col gap-6">
            {typeScale.map(t => (
              <div class="border-t border-token pt-5">
                <p class="type-label mb-3">{t.label}<span style="color: var(--fg-secondary); font-weight: 400; text-transform: none; letter-spacing: normal;"> / {t.font} / {t.size}</span></p>
                <p class={t.class}>
                  {t.class === 'type-label' ? 'UPPERCASE LABEL TEXT' : t.class === 'type-link' ? 'Inline link style' : 'The quick brown fox'}
                </p>
              </div>
            ))}
          </div>

          {/* Font families */}
          <div class="mt-10">
            <p class="type-label mb-4">Font families</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="font-display font-bold text-display-md mb-2">Aa</p>
                <p class="font-bold text-body-sm">Cabinet Grotesk</p>
                <p class="text-body-sm" style="color: var(--fg-secondary);">Display headings</p>
              </div>
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="font-body font-bold text-display-md mb-2">Aa</p>
                <p class="font-bold text-body-sm">Areal</p>
                <p class="text-body-sm" style="color: var(--fg-secondary);">Body, UI, labels</p>
              </div>
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="font-editorial italic text-display-md mb-2">Aa</p>
                <p class="font-bold text-body-sm">Ogg</p>
                <p class="text-body-sm" style="color: var(--fg-secondary);">Editorial accent</p>
              </div>
            </div>
          </div>
        </section>

        {/* Spacing */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-sm mb-3">Spacing</h2>
          <p class="type-body mb-8" style="color: var(--fg-secondary);">4px base grid. Standard Tailwind numeric scale.</p>
          <div class="flex flex-col gap-3">
            {spacingSteps.map(s => (
              <div class="flex items-center gap-4">
                <div class="flex items-center justify-end" style="width: 60px;">
                  <code class="text-body-sm" style="color: var(--fg-secondary);">{s.px}px</code>
                </div>
                <div
                  class="rounded-sm"
                  style={`width: ${s.px}px; height: 24px; background-color: var(--accent); opacity: 0.3;`}
                />
                <code class="text-body-sm">{s.tw}</code>
              </div>
            ))}
          </div>
        </section>

        {/* Components */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-sm mb-8">Components</h2>

          {/* Buttons */}
          <div class="mb-12">
            <p class="type-label mb-4">Button</p>
            <div class="flex flex-wrap items-center gap-4 mb-6">
              <Button variant="primary">Primary</Button>
              <Button variant="secondary">Secondary</Button>
              <Button variant="tertiary">Tertiary</Button>
              <Button variant="link">Link</Button>
            </div>
            <div class="flex flex-wrap items-center gap-4">
              <Button variant="primary" size="sm">Small</Button>
              <Button variant="primary" size="md">Medium</Button>
              <Button variant="primary" size="lg">Large</Button>
            </div>
          </div>

          {/* Badges */}
          <div class="mb-12">
            <p class="type-label mb-4">Badge</p>
            <div class="flex flex-wrap gap-2">
              <Badge>Figma</Badge>
              <Badge>React</Badge>
              <Badge>Tailwind</Badge>
              <Badge>User Research</Badge>
              <Badge>Design Systems</Badge>
            </div>
          </div>

          {/* Cards */}
          <div class="mb-12">
            <p class="type-label mb-4">Card</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-surface rounded-xl p-6 border border-token shadow-section-down relative z-10">
                <p class="type-display-sm mb-2">Card with shadow</p>
                <p class="type-body" style="color: var(--fg-secondary);">Surface background with section shadow for depth.</p>
              </div>
              <div class="media-card p-6" style="line-height: normal;">
                <p class="type-display-sm mb-2">Media card</p>
                <p class="type-body" style="color: var(--fg-secondary);">Tinted container for images and video.</p>
              </div>
            </div>
          </div>
        </section>

        {/* Animations */}
        <section data-animate>
          <h2 class="type-display-sm mb-3">Animations</h2>
          <p class="type-body mb-8" style="color: var(--fg-secondary);">CSS only. No JS animation libraries. Respects <code>prefers-reduced-motion</code>.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-surface rounded-xl p-6 border border-token">
              <p class="type-label mb-3">Scroll reveal</p>
              <p class="type-body" style="color: var(--fg-secondary);">
                <code>data-animate</code> (fade + translateY) and <code>data-animate-y</code> (translateY only, VoiceOver safe for headings).
              </p>
            </div>
            <div class="bg-surface rounded-xl p-6 border border-token">
              <p class="type-label mb-3">Theme transition</p>
              <p class="type-body" style="color: var(--fg-secondary);">
                All color properties transition over 300ms. Toggle the theme to see it.
              </p>
            </div>
          </div>
        </section>

      </div>
    </Container>
  </div>
</Layout>
