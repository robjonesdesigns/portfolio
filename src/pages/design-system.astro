---
import Layout from '../layouts/Layout.astro'
import Container from '../components/layout/Container.astro'
import Button from '../components/ui/Button.astro'
import Badge from '../components/ui/Badge.astro'
import ViewportPreview from '../components/ui/ViewportPreview.astro'

const colors = [
  { name: '--bg',           label: 'Background',       light: '#fffbf5', dark: '#1c1a16' },
  { name: '--bg-subtle',    label: 'Background Subtle', light: '#fdf8f2', dark: '#201e1a' },
  { name: '--surface',      label: 'Surface',           light: '#f4f1ec', dark: '#28251f' },
  { name: '--fg',           label: 'Foreground',        light: '#222222', dark: '#fffbf5' },
  { name: '--fg-secondary', label: 'Secondary',         light: '#6e6562', dark: '#c2bab0' },
  { name: '--accent',       label: 'Accent',            light: '#813746', dark: '#e36f86' },
  { name: '--on-accent',    label: 'On Accent',         light: '#fffbf5', dark: '#1c1a16' },
  { name: '--border',       label: 'Border',            light: 'rgba(92,82,80,0.1)', dark: 'rgba(176,168,158,0.1)', note: 'Uses alpha transparency so one token works on all three background layers.' },
]

const typeScale = [
  { class: 'type-display-2xl', label: 'Display 2XL', size: 'clamp(48-96px)', font: 'Cabinet Grotesk' },
  { class: 'type-display-xl',  label: 'Display XL',  size: 'clamp(40-80px)', font: 'Cabinet Grotesk' },
  { class: 'type-display-lg',  label: 'Display LG',  size: 'clamp(32-60px)', font: 'Cabinet Grotesk' },
  { class: 'type-display-md',  label: 'Display MD',  size: 'clamp(24-36px)', font: 'Cabinet Grotesk' },
  { class: 'type-display-sm',  label: 'Display SM',  size: 'clamp(20-24px)', font: 'Cabinet Grotesk' },
  { class: 'type-body',        label: 'Body',         size: '16px / 20px',    font: 'Areal' },
  { class: 'type-label',       label: 'Label',        size: '16px / 20px',    font: 'Areal', note: 'Uppercase, bold' },
  { class: 'type-link',        label: 'Link',         size: '16px / 20px',    font: 'Areal' },
  { class: 'type-badge',       label: 'Badge',        size: '16px / 20px',    font: 'Areal' },
  { class: 'type-meta',        label: 'Meta',         size: '14px',           font: 'Areal', note: 'Secondary color, no responsive step' },
]

const spacingSteps = [
  { px: 4,   tw: '1',  label: 'xs' },
  { px: 8,   tw: '2',  label: 'sm' },
  { px: 12,  tw: '3',  label: '' },
  { px: 16,  tw: '4',  label: 'md' },
  { px: 24,  tw: '6',  label: 'lg' },
  { px: 32,  tw: '8',  label: 'xl' },
  { px: 48,  tw: '12', label: '2xl' },
  { px: 64,  tw: '16', label: '3xl' },
  { px: 96,  tw: '24', label: '4xl' },
]
---

<Layout title="Design System | Rob Jones">
  <div class="bg-subtle">
    <Container>
      <div class="pt-28 md:pt-36 pb-16 md:pb-24">

        {/* Header */}
        <div class="mb-16" data-animate-y>
          <h1 class="type-display-xl mb-4">Design System</h1>
          <p class="type-body max-w-2xl">
            The design system behind this portfolio. Color tokens and typography are defined as CSS custom properties and composition classes in <code>globals.css</code>. Layout, spacing, and responsive behavior use Tailwind v3 utility classes. Toggle the theme to see both modes.
          </p>
        </div>

        {/* Colors */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-md mb-3">Color Tokens</h2>
          <p class="type-body text-fg-secondary mb-8">Defined as CSS custom properties in <code>globals.css</code> with light and dark values. Mapped to Tailwind via <code>tailwind.config.js</code> so utilities like <code>text-fg</code> and <code>bg-surface</code> resolve to the active theme.</p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {colors.map(c => (
              <div class="flex flex-col gap-2">
                <div
                  class="rounded-lg border border-token-strong h-20"
                  style={`background-color: var(${c.name});`}
                />
                <p class="type-body">{c.label}</p>
                <p class="type-meta"><code>{c.name}</code></p>
                <p class="type-meta">Light: {c.light}</p>
                <p class="type-meta">Dark: {c.dark}</p>
                {c.note && <p class="type-meta text-fg-secondary mt-1">{c.note}</p>}
              </div>
            ))}
          </div>

          {/* Noise overlay note */}
          <div class="mt-10 mb-10">
            <p class="type-label mb-4">Noise overlay</p>
            <p class="type-body text-fg-secondary">A fractal noise SVG texture covers all surfaces at 2.5% opacity via <code>.noise::after</code>, adding analog grain to flat backgrounds. Color picker values will differ from token hex values by 1-2 units due to compositing.</p>
          </div>

        </section>

        {/* Accessibility */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-md mb-3">Accessibility</h2>
          <p class="type-body text-fg-secondary mb-8">Every text and background combination used on this site meets WCAG 2.1 AA. Accessibility is structural, not an afterthought.</p>

          <p class="type-label mb-4">Light theme</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
            <div class="rounded-lg border border-token p-5 flex items-center gap-4" style="background-color: #fffbf5;">
              <span class="type-body" style="color: #222222; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #6e6562;">--fg on --bg (#fffbf5)</p>
                <p class="type-meta" style="color: #6e6562;">15.43:1 -- AAA</p>
              </div>
            </div>
            <div class="rounded-lg border border-token p-5 flex items-center gap-4" style="background-color: #fffbf5;">
              <span class="type-body" style="color: #6e6562; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #6e6562;">--fg-secondary on --bg (#fffbf5)</p>
                <p class="type-meta" style="color: #6e6562;">5.50:1 -- AA</p>
              </div>
            </div>
            <div class="rounded-lg border border-token p-5 flex items-center gap-4" style="background-color: #fdf8f2;">
              <span class="type-body" style="color: #6e6562; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #6e6562;">--fg-secondary on --bg-subtle (#fdf8f2)</p>
                <p class="type-meta" style="color: #6e6562;">5.37:1 -- AA</p>
              </div>
            </div>
            <div class="rounded-lg border border-token p-5 flex items-center gap-4" style="background-color: #f4f1ec;">
              <span class="type-body" style="color: #6e6562; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #6e6562;">--fg-secondary on --surface (#f4f1ec)</p>
                <p class="type-meta" style="color: #6e6562;">5.04:1 -- AA</p>
              </div>
            </div>
            <div class="rounded-lg border border-token p-5 flex items-center gap-4" style="background-color: #fffbf5;">
              <span class="type-body" style="color: #813746; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #6e6562;">--accent on --bg (#fffbf5)</p>
                <p class="type-meta" style="color: #6e6562;">7.93:1 -- AAA</p>
              </div>
            </div>
          </div>

          <p class="type-label mb-4">Dark theme</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="rounded-lg p-5 flex items-center gap-4" style="background-color: #1c1a16; border: 1px solid rgba(176,168,158,0.2);">
              <span class="type-body" style="color: #fffbf5; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #c2bab0;">--fg on --bg (#1c1a16)</p>
                <p class="type-meta" style="color: #c2bab0;">16.85:1 -- AAA</p>
              </div>
            </div>
            <div class="rounded-lg p-5 flex items-center gap-4" style="background-color: #1c1a16; border: 1px solid rgba(176,168,158,0.2);">
              <span class="type-body" style="color: #c2bab0; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #c2bab0;">--fg-secondary on --bg (#1c1a16)</p>
                <p class="type-meta" style="color: #c2bab0;">9.05:1 -- AAA</p>
              </div>
            </div>
            <div class="rounded-lg p-5 flex items-center gap-4" style="background-color: #201e1a; border: 1px solid rgba(176,168,158,0.2);">
              <span class="type-body" style="color: #c2bab0; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #c2bab0;">--fg-secondary on --bg-subtle (#201e1a)</p>
                <p class="type-meta" style="color: #c2bab0;">8.67:1 -- AAA</p>
              </div>
            </div>
            <div class="rounded-lg p-5 flex items-center gap-4" style="background-color: #28251f; border: 1px solid rgba(176,168,158,0.2);">
              <span class="type-body" style="color: #c2bab0; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #c2bab0;">--fg-secondary on --surface (#28251f)</p>
                <p class="type-meta" style="color: #c2bab0;">7.96:1 -- AAA</p>
              </div>
            </div>
            <div class="rounded-lg p-5 flex items-center gap-4" style="background-color: #1c1a16; border: 1px solid rgba(176,168,158,0.2);">
              <span class="type-body" style="color: #e36f86; font-size: 2rem;">Aa</span>
              <div class="flex flex-col gap-2">
                <p class="type-meta" style="color: #c2bab0;">--accent on --bg (#1c1a16)</p>
                <p class="type-meta" style="color: #c2bab0;">5.70:1 -- AA</p>
              </div>
            </div>
          </div>

          {/* Accessibility features */}
          <p class="type-label mt-10 mb-4">Implementation</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-2">Skip link</p>
              <p class="type-body text-fg-secondary">"Skip to main content" hidden until keyboard focus. Lets screen reader and keyboard users bypass the nav.</p>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-2">Focus-visible</p>
              <p class="type-body text-fg-secondary">Accent-colored ring on keyboard focus only. No ring on mouse click. Consistent across all interactive elements.</p>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-2">Reduced motion</p>
              <p class="type-body text-fg-secondary">All animations and transitions disabled via <code>prefers-reduced-motion: reduce</code>. No partial reductions.</p>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-2">VoiceOver-safe animations</p>
              <p class="type-body text-fg-secondary"><code>data-animate-y</code> uses translateY only (no opacity) so headings are always discoverable by screen readers.</p>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-2">ARIA labels</p>
              <p class="type-body text-fg-secondary">Dynamic labels on theme toggle, hamburger menu, and email copy button. States update on interaction.</p>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-2">Semantic landmarks</p>
              <p class="type-body text-fg-secondary"><code>nav</code>, <code>main</code>, <code>footer</code> with <code>aria-label</code> on navigation regions. Sitemap uses labeled nav.</p>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-2">Focus trap</p>
              <p class="type-body text-fg-secondary">Mobile nav overlay traps keyboard focus within links and the hamburger button. Escape closes the overlay.</p>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-2">Color never alone</p>
              <p class="type-body text-fg-secondary">Status and emphasis always pair color with text or shape. No information conveyed through color alone (WCAG 1.4.1).</p>
            </div>
          </div>
        </section>

        {/* Typography */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-md mb-3">Typography</h2>
          <p class="type-body text-fg-secondary mb-8">Composition classes defined in <code>@layer components</code> in <code>globals.css</code>. Display sizes use fluid <code>clamp()</code> for smooth scaling across viewports. Body sizes step at the <code>md</code> breakpoint (16px to 20px).</p>
          <div class="flex flex-col gap-6">
            {typeScale.map(t => (
              <div class="border-t border-token pt-5">
                <p class="type-label mb-3">
                  {t.label}
                </p>
                <p class="type-meta mb-3">{t.font} / {t.size}</p>
                <p class={t.class}>
                  {t.class === 'type-label' ? 'UPPERCASE LABEL TEXT' : t.class === 'type-link' ? 'Inline link style' : t.class === 'type-meta' ? 'Small metadata text' : 'The quick brown fox'}
                </p>
              </div>
            ))}
          </div>

          {/* Font families */}
          <div class="mt-10">
            <p class="type-label mb-4">Font families</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="type-display-md mb-2">Aa</p>
                <p class="type-body">Cabinet Grotesk</p>
                <p class="type-body text-fg-secondary">Display headings</p>
              </div>
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="type-display-md mb-2" style="font-family: Areal, Arial, sans-serif; font-weight: 700;">Aa</p>
                <p class="type-body">Areal</p>
                <p class="type-body text-fg-secondary">Body, UI, labels</p>
              </div>
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="type-display-md mb-2" style="font-family: Ogg, Georgia, serif; font-style: italic; font-weight: 400;">Aa</p>
                <p class="type-body">Ogg</p>
                <p class="type-body text-fg-secondary">Editorial accent</p>
              </div>
            </div>
          </div>

          {/* Code element */}
          <div class="mt-10">
            <p class="type-label mb-4">Code</p>
            <div class="bg-surface rounded-lg p-5 border border-token">
              <p class="type-body mb-4">
                The <code>code</code> element inherits its parent's font size and uses --fg-secondary text on a --surface background with a subtle border.
              </p>
              <p class="type-body">
                Example: use <code>globals.css</code> for token definitions and <code>tailwind.config.js</code> for utility mapping.
              </p>
            </div>
          </div>
        </section>

        {/* Layout */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-md mb-3">Layout</h2>
          <p class="type-body text-fg-secondary mb-8">Responsive layout using Tailwind utilities. No custom grid system.</p>

          {/* Container */}
          <div class="mb-10">
            <p class="type-label mb-4">Container</p>
            <p class="type-body text-fg-secondary mb-4">All page content wraps in a <code>Container</code> component: <code>max-w-7xl</code> (1280px), centered with <code>mx-auto</code>, and <code>px-6</code> (24px) side padding. On viewports narrower than 1280px, the max-width has no effect and the padding creates the gutter.</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="type-body mb-2">Default (lg)</p>
                <p class="type-meta">max-w-7xl / 1280px</p>
              </div>
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="type-body mb-2">Medium (md)</p>
                <p class="type-meta">max-w-4xl / 896px</p>
              </div>
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="type-body mb-2">Small (sm)</p>
                <p class="type-meta">max-w-3xl / 768px</p>
              </div>
            </div>
          </div>

          {/* Viewport Preview */}
          <div class="mb-10">
            <p class="type-label mb-4">Viewport preview</p>
            <p class="type-body text-fg-secondary mb-4">Drag the handle to resize the preview and see how the layout responds. Cards reflow from 1 column (mobile) to 2 columns (sm, 640px) to 4 columns (md, 768px). The highlighted edges show the 24px gutters. When the width exceeds 1280px, a dashed line marks the container boundary.</p>
            <ViewportPreview />
          </div>

          {/* Breakpoints */}
          <div class="mb-10">
            <p class="type-label mb-4">Breakpoints</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="type-body mb-2">sm (640px)</p>
                <p class="type-meta">Case study nav stacks to side-by-side</p>
              </div>
              <div class="bg-surface rounded-lg p-5 border border-token">
                <p class="type-body mb-2">md (768px)</p>
                <p class="type-meta">Desktop nav visible, hamburger hidden. Body text steps to 20px. Grids expand to multi-column.</p>
              </div>
            </div>
          </div>

          {/* Three-layer structure */}
          <div class="mb-10">
            <p class="type-label mb-4">Three-layer structure</p>
            <p class="type-body text-fg-secondary mb-4">Every page uses three background layers. Shadows mark the transitions between them. Cards sit on the middle layer.</p>
            <div class="rounded-xl p-6 border border-token bg-[var(--bg)]">
              <p class="type-meta mb-3">--bg (nav, hero, footer)</p>
              <div class="bg-subtle rounded-lg p-5 border border-token">
                <p class="type-meta mb-3">--bg-subtle (content sections)</p>
                <div class="bg-surface rounded-md p-4 border border-token">
                  <p class="type-meta">--surface (cards)</p>
                </div>
              </div>
            </div>
          </div>

          {/* Spacing */}
          <div>
            <p class="type-label mb-4">Spacing</p>
            <p class="type-body text-fg-secondary mb-4">4px base grid using the standard Tailwind numeric scale. All spacing uses utility classes (<code>gap-4</code>, <code>p-6</code>, <code>mb-8</code>).</p>
            <div class="flex flex-wrap items-end gap-6">
              {spacingSteps.map(s => (
                <div class="flex flex-col items-center gap-2">
                  <div
                    class="rounded-sm opacity-30"
                    style={`width: ${s.px}px; height: ${s.px}px; background-color: var(--accent);`}
                  />
                  <code class="type-meta">{s.px}px</code>
                  <code class="type-meta">t-{s.tw}</code>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* Components */}
        <section class="mb-20" data-animate>
          <h2 class="type-display-md mb-3">Components</h2>
          <p class="type-body text-fg-secondary mb-8">Astro components in <code>src/components/ui/</code>. Styled with Tailwind utilities and design tokens. No client-side JavaScript shipped for any component.</p>

          {/* Buttons */}
          <div class="mb-12">
            <p class="type-label mb-4">Button</p>
            <div class="flex flex-wrap items-center gap-4 mb-6">
              <Button variant="primary">Primary</Button>
              <Button variant="secondary">Secondary</Button>
              <Button variant="tertiary">Tertiary</Button>
              <Button variant="link">Link</Button>
            </div>
            <div class="flex flex-wrap items-center gap-4">
              <Button variant="primary" size="sm">Small</Button>
              <Button variant="primary" size="md">Medium</Button>
              <Button variant="primary" size="lg">Large</Button>
            </div>
          </div>

          {/* Badges */}
          <div class="mb-12">
            <p class="type-label mb-4">Badge</p>
            <div class="flex flex-wrap gap-2">
              <Badge>Figma</Badge>
              <Badge>React</Badge>
              <Badge>Tailwind</Badge>
              <Badge>User Research</Badge>
              <Badge>Design Systems</Badge>
            </div>
          </div>

          {/* Cards */}
          <div class="mb-12">
            <p class="type-label mb-4">Card</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-surface rounded-xl p-6 border border-token">
                <p class="type-display-sm mb-2">Card</p>
                <p class="type-body text-fg-secondary">Surface background with border for elevation. Shadows are reserved for section boundaries.</p>
              </div>
              <div class="media-card p-6">
                <p class="type-display-sm mb-2">Media card</p>
                <p class="type-body text-fg-secondary">Tinted container for images and video.</p>
              </div>
            </div>
          </div>
        </section>

        {/* Animations */}
        <section data-animate>
          <h2 class="type-display-md mb-3">Animations</h2>
          <p class="type-body text-fg-secondary mb-8">CSS only. No JS animation libraries. Respects <code>prefers-reduced-motion</code>.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-surface rounded-xl p-6 border border-token">
              <p class="type-label mb-3">Scroll reveal</p>
              <p class="type-body text-fg-secondary">
                <code>data-animate</code> (fade + translateY) and <code>data-animate-y</code> (translateY only, VoiceOver safe for headings).
              </p>
            </div>
            <div class="bg-surface rounded-xl p-6 border border-token">
              <p class="type-label mb-3">Theme transition</p>
              <p class="type-body text-fg-secondary">
                All color properties transition over 300ms. Toggle the theme to see it.
              </p>
            </div>
          </div>
        </section>

      </div>
    </Container>
  </div>
</Layout>
