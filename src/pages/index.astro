---
import Layout from '../layouts/Layout.astro'
import AppShell from '../components/AppShell.jsx'
import Hero from '../components/sections/Hero.jsx'
import Projects from '../components/sections/Projects.jsx'
import About from '../components/sections/About.jsx'

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Rob Jones',
  jobTitle: 'Product Designer',
  url: 'https://robjonesportfolio.vercel.app',
  email: 'robjonesdesigns@gmail.com',
  sameAs: ['https://linkedin.com/in/robjonesdesigner'],
}
---

<Layout
  description="Rob Jones is a UX Designer for enterprise SaaS and product builder for founders. View case studies for Honeywell, Aysa, and Keytrn."
  canonical="/"
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <AppShell client:load>
    <Hero />
    <Projects />
    <About />
  </AppShell>
</Layout>
