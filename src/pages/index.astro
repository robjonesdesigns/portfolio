---
import Layout from '../layouts/Layout.astro'
import HomePage from '../components/pages/HomePage.jsx'

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Rob Jones',
  jobTitle: 'Product Designer',
  url: 'https://designedbyrob.com',
  email: 'robjonesdesigns@gmail.com',
  sameAs: ['https://linkedin.com/in/robjonesdesigner'],
}
---

<Layout
  description="Rob Jones is a UX Designer for enterprise SaaS and product builder for founders. View case studies for Honeywell, Aysa, and Keytrn."
  canonical="/"
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <HomePage client:load />
</Layout>
