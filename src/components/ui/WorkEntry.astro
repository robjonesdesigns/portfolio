---
import LazyVideo from './LazyVideo.astro'

interface Props {
  project: any
  index?: number
}

const { project, index = 0 } = Astro.props
const { slug, headline, company, role, description, metaProblem, outcomes, images, color, video, videoGrid, mobileCardColor } = project

// Determine media type
const validVideos = videoGrid ? videoGrid.filter(Boolean) : []
const hasVideoGrid = validVideos.length > 0
const hasLaptop = !hasVideoGrid && !!video
// Filter out null/undefined image entries so no placeholders render
const validImages = (!hasVideoGrid && !hasLaptop && images) ? images.filter(Boolean) : []
const hasImages = validImages.length > 0

// ImageGrid helpers
const imageCount = hasImages ? validImages.length : 0
const firstImage = hasImages ? validImages[0] : null
const restImages = hasImages && validImages.length > 2 ? validImages.slice(1) : []
---

<article
  id={index === 0 ? 'first-project' : undefined}
  tabindex={index === 0 ? -1 : undefined}
  class="py-8 border-t border-token"
  data-animate-y
>
  <h3 class="type-display-md mb-8 md:mb-10">
    {headline}
  </h3>

  <div data-animate>

    <div class="mb-5">

      {/* VideoGrid */}
      {hasVideoGrid && validVideos.length === 1 && (
        <div class="w-full overflow-hidden rounded-lg bg-black">
          <LazyVideo src={validVideos[0]} style="width: 100%; display: block;" />
        </div>
      )}

      {hasVideoGrid && validVideos.length > 1 && (
        <div class="flex flex-col gap-3">
          <div class="overflow-hidden rounded-lg border border-media">
            <LazyVideo src={validVideos[0]} style="width: 100%; display: block;" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" style="min-height: 0;">
            {(() => {
              const secondRow = validVideos.slice(1)
              // Alternate mobile card position: even index = mobile left, odd = mobile right
              const mobileIdx = secondRow.findIndex((s: string) => s && s.includes('mobile'))
              if (mobileIdx >= 0 && index % 2 === 1) {
                // Move mobile to end for odd-indexed projects
                const mobile = secondRow.splice(mobileIdx, 1)[0]
                secondRow.push(mobile)
              } else if (mobileIdx > 0 && index % 2 === 0) {
                // Move mobile to start for even-indexed projects
                const mobile = secondRow.splice(mobileIdx, 1)[0]
                secondRow.unshift(mobile)
              }
              return secondRow
            })().map((src: string) =>
              src && src.includes('mobile') ? (
                <div class="flex items-center justify-center rounded-lg p-3 sm:p-4" style={`min-height: 100%; background-color: ${mobileCardColor || 'var(--media-bg)'};`}>
                  <div class="overflow-hidden rounded-lg bg-black" style="max-width: 160px; width: 100%;">
                    <LazyVideo src={src} style="width: 100%; display: block;" />
                  </div>
                </div>
              ) : (
                <div class="overflow-hidden rounded-lg border border-media" style="min-height: 100%;">
                  <LazyVideo src={src} style="width: 100%; height: 100%; display: block; object-fit: cover;" />
                </div>
              )
            )}
          </div>
        </div>
      )}

      {/* LaptopFrame */}
      {hasLaptop && (
        <div
          class="media-card relative rounded-2xl border border-token pt-8 px-[3%]"
          style="line-height: normal;"
        >
          <div
            class="absolute inset-0 pointer-events-none"
            style={`background: radial-gradient(ellipse 80% 50% at 50% 0%, ${color}22 0%, transparent 70%);`}
          />
          <div class="relative" style="filter: drop-shadow(0 20px 40px var(--laptop-shadow)); transform: translateY(30px);">
            <div class="relative" style="background: var(--laptop-bezel); border: 1px solid var(--laptop-border); border-radius: 10px; padding: 16px 16px 12px;">
              <div class="absolute left-1/2 -translate-x-1/2" style="top: 7px; width: 6px; height: 6px; border-radius: 50%; background: var(--laptop-camera);" />
              <div class="overflow-hidden rounded-sm bg-black" style="line-height: 0; aspect-ratio: 16/9;">
                <LazyVideo src={video} style="width: 100%; height: 100%; display: block; object-fit: cover;" />
              </div>
            </div>
          </div>
        </div>
      )}

      {/* ImageGrid — 1 image */}
      {hasImages && imageCount === 1 && (
        <div class="w-full" style="aspect-ratio: 16/9;">
          <img src={firstImage} alt="" class="w-full h-full object-cover rounded-sm" />
        </div>
      )}

      {/* ImageGrid — 2 images */}
      {hasImages && imageCount === 2 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {validImages.map((src: string) => (
            <div style="aspect-ratio: 4/3;">
              <img src={src} alt="" class="w-full h-full object-cover rounded-sm" />
            </div>
          ))}
        </div>
      )}

      {/* ImageGrid — 3+ images */}
      {hasImages && imageCount >= 3 && (
        <div class="flex flex-col gap-3">
          <div style="aspect-ratio: 16/9;">
            <img src={firstImage} alt="" class="w-full h-full object-cover rounded-sm" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {restImages.map((src: string) => (
              <div style="aspect-ratio: 4/3;">
                <img src={src} alt="" class="w-full h-full object-cover rounded-sm" />
              </div>
            ))}
          </div>
        </div>
      )}

    </div>

    {/* See more */}
    <div class="mb-10 md:mb-12">
      <a
        href={`/projects/${slug}`}
        aria-label={`See more: ${headline}`}
        class="group inline-flex items-center gap-1.5 py-2 -mx-2 px-2 type-link font-medium"
      >
        <span>See more</span>
        <span class="transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>

    {/* Metadata row */}
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      <div>
        <p class="type-badge font-bold mb-2 uppercase tracking-wide">Company</p>
        <p class="type-body">{company}</p>
      </div>
      <div>
        <p class="type-badge font-bold mb-2 uppercase tracking-wide">Role</p>
        <p class="type-body">{role}</p>
      </div>
      <div>
        <p class="type-badge font-bold mb-2 uppercase tracking-wide">Problem</p>
        <p class="type-body">{metaProblem || description}</p>
      </div>
      <div>
        <p class="type-badge font-bold mb-2 uppercase tracking-wide">Outcome</p>
        <ul class="flex flex-col gap-2">
          {(outcomes || []).map((item: string) => (
            <li class="flex gap-2 type-body">
              <span class="text-brand-primary shrink-0 leading-relaxed">&#9675;</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

  </div>
</article>
