---
interface Props {
  src: string
  style?: string
  class?: string
}

const { src, style = '', class: className = '' } = Astro.props
---

<video
  data-lazy-video
  data-src={src}
  muted
  loop
  playsinline
  preload="none"
  aria-hidden="true"
  style={style}
  class={className}
/>

<script is:inline>
  (function() {
    if (window.__lazyVideoInit) return;
    window.__lazyVideoInit = true;

    function initLazyVideos() {
      var videos = document.querySelectorAll('video[data-lazy-video]:not([src])');
      if (!videos.length) return;

      if (!('IntersectionObserver' in window)) {
        // Fallback: load all videos immediately
        videos.forEach(function(video) {
          var src = video.getAttribute('data-src');
          if (src) {
            video.src = src;
            video.autoplay = true;
          }
        });
        return;
      }

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var video = entry.target;
            var src = video.getAttribute('data-src');
            if (src) {
              video.src = src;
              video.autoplay = true;
            }
            observer.unobserve(video);
          }
        });
      }, { rootMargin: '600px' });

      videos.forEach(function(v) { observer.observe(v); });
    }

    initLazyVideos();
    document.addEventListener('astro:after-swap', initLazyVideos);
  })();
</script>
