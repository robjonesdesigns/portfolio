---
interface Props {
  src: string
  style?: string
  class?: string
}

const { src, style = '', class: className = '' } = Astro.props
---

<video
  data-lazy-video
  data-src={src}
  muted
  loop
  playsinline
  preload="none"
  aria-hidden="true"
  style={style}
  class={className}
/>

<script>
  function initLazyVideos() {
    const videos = document.querySelectorAll('video[data-lazy-video]:not([src])')
    if (!videos.length) return

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const video = entry.target as HTMLVideoElement
          const src = video.dataset.src
          if (src) {
            video.src = src
            video.autoplay = true
          }
          observer.unobserve(video)
        }
      })
    }, { rootMargin: '600px' })

    videos.forEach(v => observer.observe(v))
  }

  initLazyVideos()
  document.addEventListener('astro:after-swap', initLazyVideos)
</script>
