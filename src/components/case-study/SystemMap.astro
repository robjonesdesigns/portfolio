---
/**
 * SystemMap.astro
 * Visual diagram of the APM dashboard's data architecture.
 * Pure CSS -- no JavaScript, no frameworks.
 * Renders the full derivation chain from raw timeline data
 * through severity logic, aggregation, and drill-down.
 */
---

<section class="system-map" aria-label="System architecture diagram">
  <h2 class="type-display-md mb-2" data-animate-y>System architecture</h2>
  <p class="type-body leading-relaxed max-w-3xl mb-10" data-animate>
    The entire dashboard derives from a single timeline of 36 events. Severity is computed, not stored. Every number on every card traces back to this chain.
  </p>

  <div class="map-container" data-animate>

    {/* Layer 1: Raw Data */}
    <div class="map-layer">
      <div class="map-node map-node--wide map-node--source">
        <span class="map-node__title">TIMELINE</span>
        <span class="map-node__count">36 events</span>
        <span class="map-node__sub">Single source of truth</span>
      </div>
    </div>

    <div class="map-connector" aria-hidden="true"><div class="map-connector__line"></div></div>

    {/* Layer 2: Severity Matrix */}
    <div class="map-layer">
      <div class="map-matrix">
        <span class="map-matrix__title">Event Severity = f(impact, criticality)</span>
        <div class="map-matrix__grid" role="table" aria-label="Severity derivation matrix">
          {/* Column headers */}
          <div class="map-matrix__cell map-matrix__cell--header" role="columnheader"></div>
          <div class="map-matrix__cell map-matrix__cell--header" role="columnheader">
            <span class="map-matrix__header-label">A</span>
            <span class="map-matrix__header-sub">Safety</span>
          </div>
          <div class="map-matrix__cell map-matrix__cell--header" role="columnheader">
            <span class="map-matrix__header-label">B</span>
            <span class="map-matrix__header-sub">Production</span>
          </div>
          <div class="map-matrix__cell map-matrix__cell--header" role="columnheader">
            <span class="map-matrix__header-label">C</span>
            <span class="map-matrix__header-sub">Support</span>
          </div>

          {/* Trip row */}
          <div class="map-matrix__cell map-matrix__cell--row-header" role="rowheader">Trip</div>
          <div class="map-matrix__cell map-matrix__cell--critical" role="cell">Critical</div>
          <div class="map-matrix__cell map-matrix__cell--critical" role="cell">Critical</div>
          <div class="map-matrix__cell map-matrix__cell--high" role="cell">High</div>

          {/* Alarm row */}
          <div class="map-matrix__cell map-matrix__cell--row-header" role="rowheader">Alarm</div>
          <div class="map-matrix__cell map-matrix__cell--critical" role="cell">Critical</div>
          <div class="map-matrix__cell map-matrix__cell--high" role="cell">High</div>
          <div class="map-matrix__cell map-matrix__cell--medium" role="cell">Medium</div>

          {/* Alert row */}
          <div class="map-matrix__cell map-matrix__cell--row-header" role="rowheader">Alert</div>
          <div class="map-matrix__cell map-matrix__cell--high" role="cell">High</div>
          <div class="map-matrix__cell map-matrix__cell--medium" role="cell">Medium</div>
          <div class="map-matrix__cell map-matrix__cell--low" role="cell">Low</div>
        </div>
      </div>
    </div>

    <div class="map-connector" aria-hidden="true"><div class="map-connector__line"></div></div>

    {/* Layer 3: Derived Data */}
    <div class="map-layer">
      <span class="map-layer__label">Derived from timeline</span>
      <div class="map-layer__row">
        <div class="map-node">
          <span class="map-node__title">ASSETS</span>
          <span class="map-node__count">10</span>
          <span class="map-node__sub">Event counts per asset</span>
        </div>
        <div class="map-node">
          <span class="map-node__title">NOTIFICATIONS</span>
          <span class="map-node__sub">Recent events, reversed</span>
        </div>
        <div class="map-node">
          <span class="map-node__title">INCIDENTS</span>
          <span class="map-node__sub">Correlated event groups</span>
        </div>
      </div>
    </div>

    <div class="map-connector" aria-hidden="true"><div class="map-connector__line"></div></div>

    {/* Layer 4: Aggregations */}
    <div class="map-layer">
      <span class="map-layer__label">Aggregated from assets</span>
      <div class="map-layer__row">
        <div class="map-node">
          <span class="map-node__title">RISK_MATRIX</span>
          <span class="map-node__sub">Events by criticality tier</span>
        </div>
        <div class="map-node">
          <span class="map-node__title">EVENT_SUMMARY</span>
          <span class="map-node__sub">Confirmed / False / New</span>
        </div>
        <div class="map-node">
          <span class="map-node__title">BAD_ACTORS</span>
          <span class="map-node__sub">Top event producers</span>
        </div>
      </div>
    </div>

    <div class="map-connector" aria-hidden="true"><div class="map-connector__line"></div></div>

    {/* Layer 5: Dashboard Sections */}
    <div class="map-layer">
      <span class="map-layer__label">Dashboard sections</span>
      <div class="map-layer__row map-layer__row--dense">
        <div class="map-node map-node--compact">
          <span class="map-node__title">System Health</span>
        </div>
        <div class="map-node map-node--compact">
          <span class="map-node__title">What Happened</span>
        </div>
        <div class="map-node map-node--compact">
          <span class="map-node__title">In Progress</span>
        </div>
        <div class="map-node map-node--compact">
          <span class="map-node__title">Needs Action</span>
        </div>
        <div class="map-node map-node--compact">
          <span class="map-node__title">Assets</span>
        </div>
      </div>
    </div>

    <div class="map-connector" aria-hidden="true"><div class="map-connector__line"></div></div>

    {/* Layer 6: Cross-component Filters */}
    <div class="map-layer">
      <span class="map-layer__label">Cross-component filtering</span>
      <div class="map-filter-row">
        <div class="map-filter-sources">
          <div class="map-node map-node--compact">
            <span class="map-node__title">RiskMatrix</span>
          </div>
          <div class="map-node map-node--compact">
            <span class="map-node__title">AlarmQuality</span>
          </div>
          <div class="map-node map-node--compact">
            <span class="map-node__title">WatchList</span>
          </div>
        </div>
        <div class="map-filter-logic">
          <div class="map-filter-arrows" aria-hidden="true">
            <div class="map-filter-arrow"></div>
            <div class="map-filter-arrow"></div>
            <div class="map-filter-arrow"></div>
          </div>
          <span class="map-filter-label">AND logic</span>
        </div>
        <div class="map-node map-node--target">
          <span class="map-node__title">AssetTable</span>
        </div>
      </div>
    </div>

    <div class="map-connector" aria-hidden="true"><div class="map-connector__line"></div></div>

    {/* Layer 7: Drill-down */}
    <div class="map-layer">
      <span class="map-layer__label">Drill-down</span>
      <div class="map-drilldown">
        <div class="map-node map-node--compact">
          <span class="map-node__title">AssetTable</span>
        </div>
        <div class="map-drilldown__arrow" aria-hidden="true"></div>
        <div class="map-node map-node--inspection">
          <span class="map-node__title">AssetInspection</span>
          <div class="map-inspection-sections">
            <span>Overview</span>
            <span>Health Scores</span>
            <span>Event Timeline</span>
            <span>Work Orders</span>
            <span>Investigations</span>
            <span>Performance</span>
            <span>Maintenance</span>
            <span>Sub-assets</span>
            <span>Documentation</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Container ── */
  .map-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    width: 100%;
  }

  /* ── Layers ── */
  .map-layer {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 8px;
  }

  .map-layer__label {
    font-family: Areal, Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    opacity: 0.7;
  }

  .map-layer__row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  @media (min-width: 768px) {
    .map-layer__row {
      flex-direction: row;
      justify-content: center;
      gap: 12px;
    }
  }

  .map-layer__row--dense {
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .map-layer__row--dense {
      gap: 8px;
    }
  }

  /* ── Nodes ── */
  .map-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 12px 20px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-align: center;
    min-width: 140px;
    width: 100%;
    max-width: 280px;
  }

  @media (min-width: 768px) {
    .map-node {
      width: auto;
      max-width: none;
    }
  }

  .map-node--wide {
    min-width: 200px;
    max-width: 320px;
    padding: 16px 32px;
  }

  .map-node--source {
    border-color: var(--accent);
    border-width: 2px;
  }

  .map-node--compact {
    padding: 8px 16px;
    min-width: auto;
    gap: 0;
  }

  .map-node--target {
    border-color: var(--accent);
    border-width: 2px;
    padding: 12px 24px;
    min-width: auto;
  }

  .map-node--inspection {
    padding: 16px 20px;
    gap: 8px;
    max-width: 320px;
    width: 100%;
  }

  @media (min-width: 768px) {
    .map-node--inspection {
      width: auto;
      max-width: none;
    }
  }

  .map-node__title {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--fg);
    letter-spacing: 0.02em;
  }

  .map-node__count {
    font-family: Areal, Arial, sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent);
  }

  .map-node__sub {
    font-family: Areal, Arial, sans-serif;
    font-size: 0.75rem;
    color: var(--fg-secondary);
    line-height: 1.3;
  }

  /* ── Inspection sub-sections ── */
  .map-inspection-sections {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
  }

  .map-inspection-sections span {
    font-family: Areal, Arial, sans-serif;
    font-size: 0.6875rem;
    color: var(--fg-secondary);
    background-color: var(--bg);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  /* ── Connectors ── */
  .map-connector {
    display: flex;
    justify-content: center;
    padding: 4px 0;
  }

  .map-connector__line {
    width: 1px;
    height: 24px;
    background-color: var(--accent);
    opacity: 0.3;
  }

  /* ── Severity Matrix ── */
  .map-matrix {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
    max-width: 420px;
  }

  .map-matrix__title {
    font-family: Areal, Arial, sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--fg-secondary);
    letter-spacing: 0.02em;
  }

  .map-matrix__grid {
    display: grid;
    grid-template-columns: auto repeat(3, 1fr);
    gap: 2px;
    width: 100%;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    padding: 2px;
  }

  .map-matrix__cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 8px 6px;
    font-family: Areal, Arial, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-align: center;
    border-radius: 4px;
    line-height: 1.2;
    gap: 1px;
  }

  @media (min-width: 768px) {
    .map-matrix__cell {
      padding: 10px 12px;
      font-size: 0.75rem;
    }
  }

  .map-matrix__cell--header {
    background: transparent;
    color: var(--fg);
    font-weight: 700;
    padding: 6px 6px 4px;
  }

  .map-matrix__header-label {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--fg);
  }

  .map-matrix__header-sub {
    font-size: 0.625rem;
    font-weight: 400;
    color: var(--fg-secondary);
  }

  .map-matrix__cell--row-header {
    background: transparent;
    color: var(--fg);
    font-weight: 700;
    text-align: right;
    justify-content: center;
    padding: 8px 10px;
    font-size: 0.75rem;
  }

  /* Severity colors using accent at varying opacities */
  .map-matrix__cell--critical {
    background-color: var(--accent);
    color: var(--on-accent);
  }

  .map-matrix__cell--high {
    background-color: color-mix(in srgb, var(--accent) 55%, var(--surface));
    color: var(--fg);
  }

  .map-matrix__cell--medium {
    background-color: color-mix(in srgb, var(--accent) 25%, var(--surface));
    color: var(--fg);
  }

  .map-matrix__cell--low {
    background-color: color-mix(in srgb, var(--accent) 10%, var(--surface));
    color: var(--fg-secondary);
  }

  /* ── Filter row (Layer 6) ── */
  .map-filter-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  @media (min-width: 768px) {
    .map-filter-row {
      flex-direction: row;
      justify-content: center;
      gap: 16px;
    }
  }

  .map-filter-sources {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .map-filter-sources {
      flex-direction: column;
      gap: 6px;
    }
  }

  .map-filter-logic {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  @media (min-width: 768px) {
    .map-filter-logic {
      flex-direction: row;
      gap: 8px;
    }
  }

  .map-filter-arrows {
    display: none;
  }

  @media (min-width: 768px) {
    .map-filter-arrows {
      display: flex;
      flex-direction: column;
      gap: 10px;
      align-items: center;
    }
  }

  .map-filter-arrow {
    width: 24px;
    height: 1px;
    background-color: var(--accent);
    opacity: 0.4;
  }

  .map-filter-label {
    font-family: Areal, Arial, sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 4px 10px;
    border: 1px solid var(--accent);
    border-radius: 4px;
    opacity: 0.8;
  }

  /* ── Drill-down row (Layer 7) ── */
  .map-drilldown {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    width: 100%;
  }

  @media (min-width: 768px) {
    .map-drilldown {
      flex-direction: row;
      justify-content: center;
      gap: 16px;
    }
  }

  .map-drilldown__arrow {
    width: 1px;
    height: 24px;
    background-color: var(--accent);
    opacity: 0.3;
  }

  @media (min-width: 768px) {
    .map-drilldown__arrow {
      width: 32px;
      height: 1px;
    }
  }
</style>
