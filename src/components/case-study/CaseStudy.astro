---
import { projects } from '../../data/projects'
import Container from '../layout/Container.astro'
import LazyVideo from '../ui/LazyVideo.astro'
import Button from '../ui/Button.astro'

interface Props {
  project: any
}

const { project } = Astro.props

// Next project navigation
const idx = projects.findIndex((p: any) => p.slug === project.slug)
const next = projects[(idx + 1) % projects.length]
---

<div class="min-h-screen">
  {/* Hero */}
  <div class="relative z-10 pt-28 md:pt-36 pb-20 shadow-section-down">
    <Container>
      <div class="flex flex-col gap-10 md:gap-14">
        <h1 class="type-display-xl" data-animate-y>
          {project.headline}
        </h1>

        {/* Meta strip */}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6" data-animate data-animate-delay="1">
          <div class="flex flex-col gap-1">
            <span class="type-badge font-bold uppercase tracking-wide">Company</span>
            <span class="type-body font-medium">{project.company}</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="type-badge font-bold uppercase tracking-wide">Role</span>
            <span class="type-body font-medium">{project.role}</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="type-badge font-bold uppercase tracking-wide">Problem</span>
            <p class="type-body">{project.metaProblem}</p>
          </div>
          <div class="flex flex-col gap-1">
            <span class="type-badge font-bold uppercase tracking-wide">Outcome</span>
            <ul class="list-reset flex flex-col gap-1">
              {project.outcomes?.map((o: string) => (
                <li class="type-body flex gap-2">
                  <span class="text-brand-primary shrink-0">&#9675;</span>
                  <span>{o}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </div>

  {/* Content */}
  <div class="py-20 bg-subtle">
    <Container>
      <div class="flex flex-col gap-20">

        {/* Overview */}
        {project.intro && (
          <div class="flex flex-col gap-5 max-w-2xl" data-animate>
            <p class="type-intro leading-relaxed">{project.intro}</p>
            {project.orientationNote && (
              <p class="type-body leading-relaxed" style="color: var(--fg-secondary);">{project.orientationNote}</p>
            )}
            {project.liveUrl && (
              <div>
                <Button
                  as="a"
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  variant="primary"
                >
                  View demo
                  <span aria-hidden="true">&rarr;</span>
                </Button>
              </div>
            )}
          </div>
        )}

        {/* Problem */}
        {project.problem && (
          <div class="flex flex-col gap-4 max-w-3xl" data-animate>
            <h2 class="type-display-md" data-animate-y>The problem</h2>
            <p class="type-body leading-relaxed">{project.problem}</p>
          </div>
        )}

        {/* Process */}
        {project.process && (
          <div class="flex flex-col gap-4 max-w-3xl" data-animate>
            <h2 class="type-display-md" data-animate-y>The work</h2>
            {Array.isArray(project.process) ? (
              project.process.map((block: any) =>
                block.type === 'bullets' ? (
                  <ul class="list-reset flex flex-col gap-2">
                    {block.items.map((item: string) => (
                      <li class="flex gap-2 type-body leading-relaxed">
                        <span class="text-brand-primary shrink-0">&#9675;</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="type-body leading-relaxed">{block.text}</p>
                )
              )
            ) : (
              <p class="type-body leading-relaxed">{project.process}</p>
            )}
          </div>
        )}

        {/* Outcome — shown when no reflection */}
        {!project.reflection && project.outcome && (
          <div class="flex flex-col gap-4 max-w-3xl" data-animate>
            <h2 class="type-display-md" data-animate-y>Outcome</h2>
            <p class="type-body leading-relaxed">{project.outcome}</p>
          </div>
        )}

        {/* Process media — with optional section labels and key insight */}
        {project.processMedia?.map((item: any) => (
          <>
            {item.beforeAfter ? (
              <div data-animate>
                <h3 class="type-display-sm mb-5">{item.label}</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div class="media-card" style="aspect-ratio: 16/10;">
                    <img src={item.beforeAfter.beforeImage} alt="Before: original design" style="width: 100%; height: 100%; object-fit: cover; object-position: top left; display: block;" loading="lazy" />
                  </div>
                  <div class="media-card" style="aspect-ratio: 16/10;">
                    {item.beforeAfter.afterVideo ? (
                      <LazyVideo src={item.beforeAfter.afterVideo} style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                    ) : item.beforeAfter.afterImage ? (
                      <img src={item.beforeAfter.afterImage} alt="After: redesigned" style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy" />
                    ) : null}
                  </div>
                </div>
                {item.caption && (
                  <p class="type-body leading-relaxed max-w-3xl mt-2">{item.caption}</p>
                )}
              </div>
            ) : item.sectionLabel ? (
              <div class="flex flex-col gap-3">
                <h2 class="type-display-md" data-animate-y>{item.sectionLabel}</h2>
                <div data-animate>
                  {(item.video || item.image) && (
                    <div class="media-card">
                      {item.video ? (
                        <LazyVideo src={item.video} style="width: 100%; display: block;" />
                      ) : (
                        <img src={item.image} alt={item.label || ''} style="width: 100%; display: block;" loading="lazy" />
                      )}
                    </div>
                  )}
                  {item.caption && (
                    <p class={`type-body leading-relaxed max-w-3xl ${(item.video || item.image) ? 'mt-2' : ''}`}>{item.caption}</p>
                  )}
                </div>
              </div>
            ) : (
              <div data-animate>
                <h3 class="type-display-sm mb-5">{item.label}</h3>
                {(item.video || item.image) && (
                  <div class="media-card">
                    {item.video ? (
                      <LazyVideo src={item.video} style="width: 100%; display: block;" />
                    ) : (
                      <img src={item.image} alt={item.label || ''} style="width: 100%; display: block;" loading="lazy" />
                    )}
                  </div>
                )}
                {item.caption && (
                  <p class={`type-body leading-relaxed max-w-3xl ${(item.video || item.image) ? 'mt-2' : ''}`}>{item.caption}</p>
                )}
              </div>
            )}

            {/* Key insight callout */}
            {item.followedByInsight && project.keyInsight && (
              <div
                class="flex flex-col gap-5 py-4 mt-8"
                style="border-left: 4px solid var(--accent); padding-left: 2rem;"
                data-animate
              >
                <span class="type-label">Key insight</span>
                <p class="type-intro leading-relaxed max-w-2xl">{project.keyInsight}</p>
              </div>
            )}
          </>
        ))}

        {/* Design Decisions */}
        {project.designDecisions?.length > 0 && (
          <div class="flex flex-col gap-10 max-w-3xl mt-12">
            <h2 class="type-display-md" data-animate-y>Key design decisions</h2>
            {project.designDecisions.map((d: any, i: number) => (
              <div class={`flex flex-col gap-10 border-t border-token ${i === 0 ? 'pt-16' : 'pt-14'}`} data-animate>
                <h3 class="type-display-sm">{d.title}</h3>
                <div class="flex flex-col gap-10">
                  <div class="flex flex-col gap-2">
                    <span class="type-label">Problem</span>
                    <p class="type-body leading-relaxed">{d.problem}</p>
                  </div>
                  <div class="flex flex-col gap-2">
                    <span class="type-label">Decision</span>
                    <p class="type-body leading-relaxed">{d.decision}</p>
                  </div>
                  <div class="flex flex-col gap-2">
                    <span class="type-label">Why</span>
                    <p class="type-body leading-relaxed">{d.why}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}

        {/* UGA Business Law Clinic */}
        {project.ugaContent !== undefined && (
          <div class="flex flex-col gap-4 max-w-2xl mt-8" data-animate>
            <h2 class="type-display-md" data-animate-y>UGA Business Law Clinic</h2>
            {project.ugaContent ? (
              <p class="type-body leading-relaxed">{project.ugaContent}</p>
            ) : (
              <p class="type-body leading-relaxed" style="opacity: 0.35; font-style: italic;">
                Content coming soon.
              </p>
            )}
          </div>
        )}

        {/* Reflection */}
        {project.reflection && (
          <div class="flex flex-col gap-4 max-w-2xl mt-16" data-animate>
            <h2 class="type-display-md" data-animate-y>Reflection</h2>
            <p class="type-body leading-relaxed">{project.reflection}</p>
          </div>
        )}

        {/* Navigation */}
        <div
          class="flex flex-col sm:flex-row sm:justify-between gap-4 pt-8 border-t border-token"
        >
          <a href="/#projects" class="type-link inline-block py-2 -mx-2 px-2">
            &larr; All projects
          </a>
          <a href={`/projects/${next.slug}`} class="type-link inline-block py-2 -mx-2 px-2">
            Next: {next.title} &rarr;
          </a>
        </div>

      </div>
    </Container>
  </div>
</div>
