---
import { projects } from '../../data/projects'
import type { DesignDecision, ProcessBlock, ProcessMediaItem, Project } from '../../types/project'
import Container from '../layout/Container.astro'
import LazyVideo from '../ui/LazyVideo.astro'
import Button from '../ui/Button.astro'
import SystemMap from './SystemMap.astro'

interface Props {
  project: Project
}

const { project } = Astro.props

// Next project navigation
const idx = projects.findIndex((p) => p.slug === project.slug)
const next = projects[(idx + 1) % projects.length]
---

<div class="min-h-screen">
  {/* Hero */}
  <div class="relative z-10 pt-28 md:pt-36 pb-20 shadow-section-down">
    <Container>
      <div class="flex flex-col gap-10 md:gap-14">
        <h1 class="type-display-xl" data-animate-y>
          {project.headline}
        </h1>

        {/* Meta strip */}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0" data-animate data-animate-delay="1">
          <div class="flex flex-col gap-1 md:pr-6">
            <span class="type-meta font-bold uppercase tracking-wide">Company</span>
            <span class="type-body font-medium">{project.company}</span>
          </div>
          <div class="flex flex-col gap-1 md:border-l md:border-token md:pl-6 md:pr-6">
            <span class="type-meta font-bold uppercase tracking-wide">Role</span>
            <span class="type-body font-medium">{project.role}</span>
          </div>
          <div class="flex flex-col gap-1 md:border-l md:border-token md:pl-6 md:pr-6">
            <span class="type-meta font-bold uppercase tracking-wide">Problem</span>
            <p class="type-body">{project.metaProblem}</p>
          </div>
          <div class="flex flex-col gap-1 md:border-l md:border-token md:pl-6">
            <span class="type-meta font-bold uppercase tracking-wide">Outcome</span>
            <ul class="list-reset flex flex-col gap-1">
              {project.outcomes?.map((o: string) => (
                <li class="type-body flex gap-2">
                  <span class="text-brand-primary shrink-0">&#9675;</span>
                  <span>{o}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </div>

  {/* Content */}
  <div class="py-20 bg-subtle">
    <Container>
      <div class="flex flex-col gap-20">

        {/* Overview */}
        {project.intro && (
          <div class="flex flex-col gap-5 max-w-2xl" data-animate>
            <p class="type-intro leading-relaxed">{project.intro}</p>
            {project.orientationNote && (
              <p class="type-body leading-relaxed text-fg-secondary">{project.orientationNote}</p>
            )}
            {project.liveUrl && (
              <div class="flex flex-col gap-2">
                <div>
                  <Button
                    as="a"
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    variant="primary"
                    size="md"
                  >
                    View demo
                    <span aria-hidden="true">&rarr;</span>
                  </Button>
                </div>
                {project.liveUrlNote && (
                  <p class="type-body-sm text-fg-secondary" set:html={project.liveUrlNote}></p>
                )}
              </div>
            )}
          </div>
        )}

        {/* Problem */}
        {project.problem && (
          <div class="flex flex-col gap-4 max-w-3xl">
            <h2 class="type-display-md" data-animate-y>The problem</h2>
            <p class="type-body leading-relaxed" data-animate>{project.problem}</p>
          </div>
        )}

        {/* Process */}
        {project.process && (
          <div class="flex flex-col gap-4 max-w-3xl">
            <h2 class="type-display-md" data-animate-y>The work</h2>
            {Array.isArray(project.process) ? (
              project.process.map((block: ProcessBlock) =>
                block.type === 'bullets' ? (
                  <ul class="list-reset flex flex-col gap-2">
                    {block.items.map((item: string) => (
                      <li class="flex gap-2 type-body leading-relaxed">
                        <span class="text-brand-primary shrink-0">&#9675;</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="type-body leading-relaxed">{block.text}</p>
                )
              )
            ) : (
              <p class="type-body leading-relaxed">{project.process}</p>
            )}
          </div>
        )}


        {/* Outcome — shown when no reflection */}
        {!project.reflection && project.outcome && (
          <div class="flex flex-col gap-4 max-w-3xl">
            <h2 class="type-display-md" data-animate-y>Outcome</h2>
            <p class="type-body leading-relaxed" data-animate>{project.outcome}</p>
          </div>
        )}

        {/* Process media — with optional section labels and key insight */}
        {project.processMedia?.map((item: ProcessMediaItem) => (
          <div class={`flex flex-col ${(item.video || item.image || item.videoGrid || item.conversations) ? 'gap-12' : 'gap-6'}`}>
            {item.beforeAfter ? (
              <div data-animate>
                <h3 class="type-display-sm mb-5">{item.label}</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div class="media-card aspect-[16/10]">
                    <img src={item.beforeAfter.beforeImage} alt="Before: original design" class="w-full h-full object-cover object-left-top block" loading="lazy" />
                  </div>
                  <div class="media-card aspect-[16/10]">
                    {item.beforeAfter.afterVideo ? (
                      <LazyVideo src={item.beforeAfter.afterVideo} class="w-full h-full object-cover block" />
                    ) : item.beforeAfter.afterImage ? (
                      <img src={item.beforeAfter.afterImage} alt="After: redesigned" class="w-full h-full object-cover block" loading="lazy" />
                    ) : null}
                  </div>
                </div>
                {item.caption && (
                  <p class="type-body leading-relaxed max-w-3xl mt-2 text-fg-secondary" set:html={item.caption}></p>
                )}
              </div>
            ) : item.sectionBreak ? (
              <div class="flex flex-col gap-5 max-w-2xl">
                <h2 class="type-display-md" data-animate-y>{item.sectionLabel || item.label}</h2>
                {item.caption && (
                  <p class="type-body leading-relaxed" data-animate>{item.caption}</p>
                )}
              </div>
            ) : item.sectionLabel ? (
              <div class="flex flex-col gap-3">
                {!item.decision?.headline && (
                  <h2 class="type-display-md" data-animate-y>{item.sectionLabel}</h2>
                )}
                {(item.label || item.video || item.image || item.videoGrid || item.caption || item.decision?.headline) && (
                  <div data-animate>
                    {item.decision?.headline && (
                      <p class="type-label mb-3">{item.sectionLabel}{item.label ? ': ' + item.label : ''}</p>
                    )}
                    {!item.decision?.headline && item.label && (
                      <p class="type-label mb-3">{item.label}</p>
                    )}
                    {item.videoGrid && item.videoGrid.length > 0 ? (
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl">
                        {item.videoGrid.map((src: string) => (
                          <div class="media-card">
                            <LazyVideo src={src} class="w-full block" />
                          </div>
                        ))}
                      </div>
                    ) : (item.video || item.image) && (
                      <div class="media-card max-w-2xl">
                        {item.video ? (
                          <LazyVideo src={item.video} class="w-full block" />
                        ) : (
                          <img src={item.image} alt={item.label || ''} class="w-full block" loading="lazy" />
                        )}
                      </div>
                    )}
                    {item.caption && (
                      <p class={`type-body leading-relaxed max-w-3xl text-fg-secondary ${(item.video || item.image || item.videoGrid) ? 'mt-2' : ''}`} set:html={item.caption}></p>
                    )}
                  </div>
                )}
              </div>
            ) : (
              <div data-animate>
                <p class="type-label mb-3">{item.label}</p>
                {item.systemMap && (
                  <div>
                    <SystemMap />
                    {item.caption && (
                      <p class="type-body leading-relaxed max-w-3xl mt-2 text-fg-secondary" set:html={item.caption}></p>
                    )}
                  </div>
                )}
                {!item.systemMap && item.videoGrid && item.videoGrid.length > 0 ? (
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl">
                    {item.videoGrid.map((src: string) => (
                      <div class="media-card aspect-[9/16]">
                        <LazyVideo src={src} class="w-full h-full object-cover block" />
                      </div>
                    ))}
                  </div>
                ) : (item.video || item.image) && (
                  <div class="media-card max-w-2xl">
                    {item.video ? (
                      <LazyVideo src={item.video} class="w-full block" />
                    ) : (
                      <img src={item.image} alt={item.label || ''} class="w-full block" loading="lazy" />
                    )}
                  </div>
                )}
                {!item.systemMap && item.caption && (
                  <p class={`type-body leading-relaxed max-w-3xl text-fg-secondary ${(item.video || item.image || item.videoGrid) ? 'mt-2' : ''}`} set:html={item.caption}></p>
                )}
              </div>
            )}

            {/* Research conversations -- Q&A cards with quote styling */}
            {item.conversations && item.conversations.length > 0 && (
              <div class="flex flex-col gap-6" data-animate>
                <span class="type-label">From the calls</span>
                <div class="flex flex-col gap-6 max-w-2xl">
                  {item.conversations.map((c, i: number) => (
                    <div class={`flex flex-col gap-3 ${i > 0 ? 'pt-6 border-t border-token' : ''}`}>
                      {/* Question card (me) */}
                      <div class="quote-card quote-card--question">
                        <span class="type-label text-[10px]">Me</span>
                        <p class="type-body leading-relaxed m-0">{c.question}</p>
                      </div>
                      {/* Response card (county) */}
                      <div class="quote-card quote-card--response">
                        <span class="type-label text-[10px] text-brand-primary">{c.source}</span>
                        <p class="type-body leading-relaxed m-0 italic">&ldquo;{c.response}&rdquo;</p>
                      </div>
                    </div>
                  ))}
                  {item.conversationsFootnote && (
                    <p class="type-body leading-relaxed mt-2 text-fg-secondary">{item.conversationsFootnote}</p>
                  )}
                </div>
              </div>
            )}

            {/* Inline design decision — editorial hero treatment */}
            {item.decision && (
              <div class="flex flex-col gap-6 max-w-3xl" data-animate>
                {item.decision.problem && (
                  <p class="type-body leading-relaxed m-0">{item.decision.problem}</p>
                )}
                {item.decision.headline && (
                  <div class="py-8 my-2 flex flex-col gap-3 border-y-[3px] border-brand-primary">
                    {item.decision.headline.includes('|') ? (
                      item.decision.headline.split('|').map((line: string) => (
                        <p class="type-display-lg m-0 text-brand-primary font-bold leading-[1.15]">{line}</p>
                      ))
                    ) : (
                      <p class="type-display-lg m-0 text-brand-primary font-bold leading-[1.15]">{item.decision.headline}</p>
                    )}
                  </div>
                )}
                {item.decision.decision && !item.decision.headline && (
                  <div class="py-8 my-2 border-y-[3px] border-brand-primary">
                    <p class="type-display-lg m-0 text-brand-primary font-bold leading-[1.15]">{item.decision.decision}</p>
                  </div>
                )}
                {item.decision.decision && item.decision.headline && (
                  <p class="type-body leading-relaxed m-0">{item.decision.decision}</p>
                )}
                {item.decision.why && (
                  <p class="type-body leading-relaxed m-0">{item.decision.why}</p>
                )}
              </div>
            )}

            {/* Key insight callout */}
            {item.followedByInsight && project.keyInsight && (
              <div
                class="flex flex-col gap-5 py-4 mt-2 border-l-4 border-brand-primary pl-8"
                data-animate
              >
                <span class="type-label">Key insight</span>
                <p class="type-intro leading-relaxed max-w-2xl">{project.keyInsight}</p>
              </div>
            )}
          </div>
        ))}


        {/* Design Decisions */}
        {project.designDecisions?.length > 0 && (
          <div class="flex flex-col gap-10 max-w-3xl mt-12">
            <h2 class="type-display-md" data-animate-y>Key design decisions</h2>
            {project.designDecisions.map((d: DesignDecision, i: number) => (
              <div class={`flex flex-col gap-10 border-t border-token ${i === 0 ? 'pt-16' : 'pt-14'}`} data-animate>
                <h3 class="type-display-sm">{d.title}</h3>
                <div class="flex flex-col gap-10">
                  <div class="flex flex-col gap-2">
                    <span class="type-label">Problem</span>
                    <p class="type-body leading-relaxed">{d.problem}</p>
                  </div>
                  <div class="flex flex-col gap-2">
                    <span class="type-label">Decision</span>
                    <p class="type-body leading-relaxed">{d.decision}</p>
                  </div>
                  <div class="flex flex-col gap-2">
                    <span class="type-label">Why</span>
                    <p class="type-body leading-relaxed">{d.why}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}

        {/* UGA Business Law Clinic */}
        {project.ugaContent !== undefined && (
          <div class="flex flex-col gap-4 max-w-2xl mt-8">
            <h2 class="type-display-md" data-animate-y>UGA Business Law Clinic</h2>
            {project.ugaContent ? (
              <p class="type-body leading-relaxed">{project.ugaContent}</p>
            ) : (
              <p class="type-body leading-relaxed opacity-[0.35] italic">
                Content coming soon.
              </p>
            )}
          </div>
        )}

        {/* Reflection */}
        {project.reflection && (
          <div class="flex flex-col gap-4 max-w-2xl mt-16">
            <h2 class="type-display-md" data-animate-y>Reflection</h2>
            <p class="type-body leading-relaxed" data-animate>{project.reflection}</p>
          </div>
        )}

        {/* Navigation */}
        <div
          class="flex flex-col sm:flex-row sm:justify-between gap-4 pt-8 border-t border-token"
        >
          <a href="/#projects" class="type-link inline-block py-2 -mx-2 px-2">
            &larr; All projects
          </a>
          <a href={`/projects/${next.slug}`} class="type-link inline-block py-2 -mx-2 px-2">
            Next: {next.title} &rarr;
          </a>
        </div>

      </div>
    </Container>
  </div>
</div>
