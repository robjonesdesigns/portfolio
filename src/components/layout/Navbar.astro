---
const currentPath = Astro.url.pathname

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Resume', href: '/resume' },
]
---

<header
  class="navbar-header"
>
  <div class="w-full h-full max-w-7xl mx-auto px-6 flex items-center justify-between">

    {/* Logo */}
    <a
      href="/"
      class="flex-shrink-0"
      tabindex={currentPath === '/' ? -1 : undefined}
    >
      <div class="logo-mark" tabindex="-1">
        <svg
          width="24"
          height="28"
          viewBox="0 -2 36 41"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="Home"
        >
          <path d="M0.5 33.5V3.5C0.5 1.56701 2.067 0 4 0C5.933 0 7.5 1.56701 7.5 3.5V33.5C7.5 35.433 5.933 37 4 37C2.067 37 0.5 35.433 0.5 33.5Z" fill="var(--accent)" />
          <path d="M29.7754 2.56878C25.5125 -0.215006 18.8015 -0.177577 14.8076 0.15553C12.8815 0.316169 11.5 1.96593 11.5 3.89868V4.46865C11.5 6.68091 13.2957 8.47306 15.508 8.46864L21.6104 8.45645C23.7893 8.4521 25.558 10.2172 25.558 12.3962C25.558 14.572 23.7941 16.3359 21.6183 16.3359H15.5C13.2909 16.3359 11.5 18.1267 11.5 20.3359V20.9626C11.5 22.8609 12.834 24.4924 14.7203 24.7057C19.1322 25.2045 26.9855 25.4831 31.1812 21.9732C37.92 16.3359 36.2508 6.79733 29.7754 2.56878Z" fill="var(--accent)" />
          <path d="M35.5 32C35.5 34.7614 33.2614 37 30.5 37C27.7386 37 25.5 34.7614 25.5 32C25.5 29.2386 27.7386 27 30.5 27C33.2614 27 35.5 29.2386 35.5 32Z" fill="var(--fg)" />
        </svg>
      </div>
    </a>

    {/* Desktop nav links + toggle */}
    <nav class="hidden md:flex items-center gap-8" aria-label="Main">
      {navLinks.map(({ label, href }) => {
        const isActive = currentPath === href || currentPath === href + '/'
        return (
          <a href={href} class="type-nav-link relative group transition-opacity duration-300">
            {label}
            <span class:list={[
              'absolute -bottom-0.5 left-0 h-px bg-brand-primary transition-all duration-300',
              isActive ? 'w-full' : 'w-0 group-hover:w-full'
            ]} />
          </a>
        )
      })}

      {/* Theme toggle (desktop -- inside nav for even spacing) */}
      <button
        data-theme-toggle
        class="theme-toggle relative w-16 h-8 rounded-full flex items-center px-1.5 border bg-surface border-token"
        aria-label="Switch color theme"
      >
        <svg class="absolute left-2 w-4 h-4" style="color: var(--fg); opacity: 0.9;" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1zm0 16a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1zm10-6a1 1 0 0 1-1 1h-1a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1zM4 12a1 1 0 0 1-1 1H2a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1zm15.07-7.07a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zM6.34 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zm12.73 1.41a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41zM6.34 6.34a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 0 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41zM12 7a5 5 0 1 1 0 10A5 5 0 0 1 12 7z"/>
        </svg>
        <svg class="absolute right-2 w-4 h-4" style="color: var(--fg); opacity: 0.9;" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
        </svg>
        <span class="theme-thumb w-5 h-5 rounded-full z-10" style="background-color: var(--accent); display: block;" />
      </button>
    </nav>

    {/* Mobile controls: theme toggle + hamburger */}
    <div class="flex md:hidden items-center gap-4">
      <button
        data-theme-toggle
        class="theme-toggle relative w-16 h-8 rounded-full flex items-center px-1.5 border bg-surface border-token"
        aria-label="Switch color theme"
      >
        <svg class="absolute left-2 w-4 h-4" style="color: var(--fg); opacity: 0.9;" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1zm0 16a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1zm10-6a1 1 0 0 1-1 1h-1a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1zM4 12a1 1 0 0 1-1 1H2a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1zm15.07-7.07a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zM6.34 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zm12.73 1.41a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41zM6.34 6.34a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 0 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41zM12 7a5 5 0 1 1 0 10A5 5 0 0 1 12 7z"/>
        </svg>
        <svg class="absolute right-2 w-4 h-4" style="color: var(--fg); opacity: 0.9;" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
        </svg>
        <span class="theme-thumb w-5 h-5 rounded-full z-10" style="background-color: var(--accent); display: block;" />
      </button>

      <button
        class="mobile-nav-toggle relative w-10 h-10 flex items-center justify-center"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav-overlay"
      >
        <span class="hamburger-line hamburger-line-1"></span>
        <span class="hamburger-line hamburger-line-2"></span>
        <span class="hamburger-line hamburger-line-3"></span>
      </button>
    </div>

  </div>
</header>

{/* Mobile nav overlay */}
<div
  id="mobile-nav-overlay"
  class="mobile-nav-overlay"
  aria-hidden="true"
>
  <nav class="mobile-nav-content" aria-label="Mobile">
    {navLinks.map(({ label, href }) => (
      <a href={href} class="mobile-nav-link type-display-md" data-mobile-nav-link>
        {label}
      </a>
    ))}

  </nav>
</div>

<!-- Theme toggle + mobile nav handlers are in Layout.astro (handles ViewTransitions) -->
